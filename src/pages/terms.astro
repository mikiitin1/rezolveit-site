---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../lib/nav";

const lang: Locale = "en";
---

<Base
  lang={lang}
  title="RezolveIT — Terms of Service"
  description="The terms that govern your use of the RezolveIT website."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/terms" />

    <header class="rz-legal-hero">
      <div class="rz-legal-hero-glow"></div>
      <div data-reveal class="rz-legal-hero-inner">
        <div class="rz-legal-eyebrow">Legal</div>
        <h1 class="rz-legal-h1">Terms of Service</h1>
        <p class="rz-legal-sub">The terms that govern your use of our website.</p>
        <span class="rz-legal-updated">Last updated: July 22, 2026</span>
      </div>
    </header>

    <section class="rz-legal-section">
      <div data-reveal class="rz-legal-panel">
        <p>
          These Terms of Service govern your use of the RezolveIT website. By using the site, you agree to them. Use
          of the RezolveIT product itself is covered by a separate subscription agreement.
        </p>
        <h3>Using the site</h3>
        <p>
          You agree to use the website lawfully and not to interfere with its operation or misuse its content. The
          site and its content are owned by RezolveIT and protected by intellectual-property laws.
        </p>
        <h3>Demos</h3>
        <p>
          When you request a demo, you authorize us to contact you about it. Any sandbox or sample environment is
          for evaluation only and may change or be withdrawn at any time.
        </p>
        <h3>Disclaimer</h3>
        <p>
          The website is provided "as is", without warranties of any kind. To the extent permitted by law, RezolveIT
          is not liable for damages arising from your use of the site.
        </p>
        <h3>Contact</h3>
        <p>Questions? Email <a href="mailto:legal@rezolveit.io">legal@rezolveit.io</a>.</p>
        <p class="rz-legal-disclaimer">
          This document is a general template and is not legal advice. Please have it reviewed by your legal counsel
          before publication.
        </p>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-legal-hero {
    position: relative;
    padding: 80px 48px 30px;
    text-align: center;
    overflow: hidden;
  }
  .rz-legal-hero-glow {
    position: absolute;
    left: 50%;
    top: 34%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 420px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.12), transparent 72%);
    pointer-events: none;
  }
  .rz-legal-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .rz-legal-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-legal-h1 {
    font-family: "Sora", sans-serif;
    font-size: clamp(34px, 4.4vw, 52px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-legal-sub {
    max-width: 600px;
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
  }
  .rz-legal-updated {
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-legal-section {
    padding: 20px 48px 60px;
    max-width: 820px;
    margin: 0 auto;
  }
  .rz-legal-panel {
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--panel);
    padding: 40px 44px;
  }
  .rz-legal-panel p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted);
    margin: 0 0 14px;
    text-wrap: pretty;
  }
  .rz-legal-panel h3 {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 26px 0 8px;
    color: var(--text);
  }
  .rz-legal-panel p.rz-legal-disclaimer {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--muted2);
    margin: 26px 0 0;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .rz-legal-panel {
      padding: 32px 26px;
    }
  }
</style>
