---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import { localePath, type Locale } from "../../lib/nav";

const lang: Locale = "he";

const vulnRows = [
  {
    tag: "CRIT",
    tagClass: "red",
    title: "CVE-2026-1177 · OpenSSL RCE",
    sub: "12 affected CIs · patch via CHG-1055",
    right: "CVSS 9.8",
    rightClass: "red",
  },
  {
    tag: "HIGH",
    tagClass: "amber",
    title: "CVE-2026-0841 · Postgres priv-esc",
    sub: "3 affected CIs · remediation planned",
    right: "CVSS 8.1",
    rightClass: "amber",
  },
  {
    tag: "MED",
    tagClass: "teal",
    title: "SEC-0092 · Phishing report — Finance",
    sub: "Contained · awaiting user comms",
    right: "Contained",
    rightClass: "teal",
  },
];

const insideCards = [
  {
    icon: "shield",
    title: "אירועי אבטחה",
    body: "רשומות אירועי אבטחה ייעודיות עם נראות מוגבלת, מצבי הכלה וסקירה שלאחר אירוע.",
  },
  {
    icon: "alert",
    title: "טיפול בחולשות",
    body: "עקבו אחר CVEs מול CIs מושפעים, תעדפו לפי CVSS וחשיפה, ותקנו דרך ניהול שינויים.",
  },
  {
    icon: "nodes",
    title: "רדיוס פגיעה מקושר-CMDB",
    body: "חולשה ממופה ל-CIs, CIs ממופים לשירותים עסקיים — ההשפעה גלויה עוד לפני מיון.",
  },
  {
    icon: "list",
    title: "מסלול ביקורת אבטחה",
    body: "התחברויות, הענקות תפקיד, החלפות מפתח ושינויי רשומות מתועדים בכל הפלטפורמה — ראיות מוכנות למבקרים.",
  },
  {
    icon: "lock",
    title: "נראות מוגבלת",
    body: "הגישה נאכפת בכל רשומה — פניות אבטחה נשארות גלויות רק לצוות האבטחה.",
  },
  {
    icon: "swap",
    title: "תיקון דרך שינוי",
    body: "טלאים עוברים באותו תהליך שינוי — כולל אישורים, חלונות זמן ותוכניות חזרה לאחור.",
  },
];
---

<Base
  lang={lang}
  title="RezolveIT — Security Ops"
  description="אירועי אבטחה וטיפול בחולשות שמקושרים ישירות ל-CIs, לנכסים ולשינויים שלכם — יחד עם מסלול ביקורת חסין-שינוי בכל רשומה בפלטפורמה."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/security-ops" />

    <header class="rz-mhero">
      <div class="rz-mhero-glow"></div>
      <div class="rz-mhero-inner">
        <div class="rz-eyebrow"><Icon name="shield" size={16} /> מודול · Security Operations</div>
        <h1 class="rz-h1">תגובת אבטחה, על אותה פלטפורמה</h1>
        <p class="rz-hero-sub">
          אירועי אבטחה וטיפול בחולשות שמקושרים ישירות ל-CIs, לנכסים ולשינויים שלכם — יחד עם מסלול ביקורת חסין-שינוי בכל
          רשומה בפלטפורמה.
        </p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </header>

    <section class="rz-mock-section">
      <div data-reveal class="rz-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Security operations</span>
        </div>
        <div class="rz-sec-grid">
          <div class="rz-sec-panel">
            <div class="rz-sec-panel-label">Vulnerability queue</div>
            {
              vulnRows.map((v) => (
                <div class="rz-sec-vuln-row">
                  <span class={`rz-sec-vuln-tag rz-sec-vuln-tag--${v.tagClass}`}>{v.tag}</span>
                  <div>
                    <div class="rz-sec-vuln-title">{v.title}</div>
                    <div class="rz-sec-vuln-sub">{v.sub}</div>
                  </div>
                  <span class={`rz-sec-vuln-right rz-sec-vuln-right--${v.rightClass}`}>{v.right}</span>
                </div>
              ))
            }
            <div class="rz-sec-ai-note">
              <span>✦</span>
              <span>AI: summarize blast radius of CVE-2026-1177 for the CAB?</span>
            </div>
          </div>
          <div class="rz-sec-panel">
            <div class="rz-sec-panel-label">Audit trail</div>
            <div class="rz-sec-audit-row">
              <span class="rz-sec-audit-time">14:22</span>
              <span class="rz-sec-audit-text">Role <span class="rz-sec-audit-strong">sec_analyst</span> granted to J. Miller — by admin</span>
            </div>
            <div class="rz-sec-audit-row">
              <span class="rz-sec-audit-time">13:57</span>
              <span class="rz-sec-audit-text">AI provider key rotated — <span class="rz-sec-audit-strong">vault event</span>, RLS verified</span>
            </div>
            <div class="rz-sec-audit-row">
              <span class="rz-sec-audit-time">13:31</span>
              <span class="rz-sec-audit-text">SEC-0092 state → <span class="rz-sec-audit-strong rz-sec-audit-strong--amber">Contained</span> — by A. Turner</span>
            </div>
            <div class="rz-sec-audit-row rz-sec-audit-row--last">
              <span class="rz-sec-audit-time">12:48</span>
              <span class="rz-sec-audit-text">Failed login × 5 — account locked, incident opened</span>
            </div>
            <div class="rz-sec-rls-note">
              <span class="rz-sec-rls-icon"><Icon name="shield" size={16} /></span>
              <span>Every record RLS-protected · full event history</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside">
      <h2 data-reveal class="rz-inside-h2">מה יש בפנים</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-card-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-cta-section">
      <div data-reveal class="rz-cta-box">
        <h2 class="rz-cta-h2">ראו את Security Ops בפעולה תוך דקות</h2>
        <p class="rz-cta-sub">כולל חולשות ואירועי ביקורת לדוגמה.</p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-hero-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    display: inline-block;
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  .rz-mhero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-mhero-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-mhero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .rz-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-sec-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 16px;
  }
  .rz-sec-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .rz-sec-panel-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .rz-sec-vuln-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px;
    border-radius: 8px;
    background: var(--inset);
  }
  .rz-sec-vuln-tag {
    font-size: 11px;
    font-weight: 700;
    border-radius: 5px;
    padding: 2px 7px;
    flex-shrink: 0;
  }
  .rz-sec-vuln-tag--red {
    color: #ff8484;
    border: 1px solid rgba(255, 132, 132, 0.4);
  }
  .rz-sec-vuln-tag--amber {
    color: #ffc46b;
    border: 1px solid rgba(255, 196, 107, 0.4);
  }
  .rz-sec-vuln-tag--teal {
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.4);
  }
  .rz-sec-vuln-title {
    font-size: 13.5px;
    color: var(--text2);
  }
  .rz-sec-vuln-sub {
    font-size: 11.5px;
    color: var(--muted2);
  }
  .rz-sec-vuln-right {
    margin-inline-start: auto;
    font-size: 11.5px;
    flex-shrink: 0;
  }
  .rz-sec-vuln-right--red {
    color: #ff8484;
  }
  .rz-sec-vuln-right--amber {
    color: #ffc46b;
  }
  .rz-sec-vuln-right--teal {
    color: var(--accent-strong);
  }
  .rz-sec-ai-note {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    background: rgba(56, 224, 200, 0.08);
    border: 1px solid rgba(56, 224, 200, 0.2);
    font-size: 12.5px;
    color: var(--accent-strong2);
  }

  .rz-sec-audit-row {
    display: flex;
    gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid var(--border0);
  }
  .rz-sec-audit-row--last {
    border-bottom: none;
  }
  .rz-sec-audit-time {
    font-size: 11.5px;
    color: var(--muted2);
    width: 52px;
    flex-shrink: 0;
  }
  .rz-sec-audit-text {
    font-size: 12.5px;
    color: var(--text2);
  }
  .rz-sec-audit-strong {
    color: var(--accent-strong);
  }
  .rz-sec-audit-strong--amber {
    color: #ffc46b;
  }
  .rz-sec-rls-note {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 9px;
    padding: 10px 12px;
    background: rgba(56, 224, 200, 0.05);
    font-size: 12.5px;
    color: var(--accent-strong);
  }
  .rz-sec-rls-icon {
    display: flex;
    color: var(--accent-strong);
  }

  .rz-inside {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-h2 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-card-icon {
    color: var(--rz-accent);
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Heebo", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  .rz-cta-section {
    padding: 0 48px 100px;
  }
  .rz-cta-box {
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-cta-h2 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-sec-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
