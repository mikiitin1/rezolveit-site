---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import type { Locale } from "../../lib/nav";

const lang: Locale = "he";

const insideCards = [
  {
    icon: "grid",
    title: "עיון בקטלוג",
    body: "עובדים מוצאים ומבקשים שירותים בקטגוריות שהמנהלים מגדירים — עם טפסים מודרכים לכל פריט.",
  },
  {
    icon: "ticket",
    title: "מעקב פניות",
    body: 'סטטוס חי, תגובות ואישורים בכל בקשה — בלי עוד מיילים של "יש עדכון?".',
  },
  {
    icon: "search",
    title: "חיפוש ידע",
    body: "חיפוש בכל הפורטל על פני פריטי קטלוג ומאמרי ידע מסיט פניות לפני שנפתחות.",
  },
  {
    icon: "palette",
    title: "מיתוג ללא קוד",
    body: "לוגו, צבעים, קטגוריות, טפסים וכותרת תחתונה — הכול בהגדרת מנהל מהממשק, לעולם לא מפתח.",
  },
  {
    icon: "phone",
    title: "ידידותי לנייד ונגיש",
    body: "פריסות רספונסיביות ונגישות מובנית — הפורטל עובד בכל מקום שבו העובדים נמצאים.",
  },
  {
    icon: "globe",
    title: "רב-לשוני",
    body: "הגדרות שפה לכל משתמש — צוותים גלובליים עובדים כל אחד בשפתו.",
  },
];
---

<Base
  lang={lang}
  title="Employee Center — Self-Service Portal | RezolveIT"
  description="עיינו בקטלוג, הגישו בקשות, עקבו אחר פניות וחפשו ידע — בפורטל ממותג, ידידותי לנייד ונגיש שהמנהלים שלכם מתאימים כולו מהממשק."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/employee-center" />

    <header class="rz-module-hero">
      <div class="rz-module-glow"></div>
      <div class="rz-module-hero-inner">
        <div class="rz-eyebrow"><Icon name="portal" size={16} /> מודול · Employee Service Center</div>
        <h1 class="rz-h1-module">פורטל שהעובדים שלכם באמת משתמשים בו</h1>
        <p class="rz-module-sub">
          עיינו בקטלוג, הגישו בקשות, עקבו אחר פניות וחפשו ידע — בפורטל ממותג, ידידותי לנייד ונגיש שהמנהלים שלכם
          מתאימים כולו מהממשק.
        </p>
        <a href="/he/contact" class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </header>

    <section class="rz-module-mock-section">
      <div data-reveal class="rz-module-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">portal.yourcompany.com — Employee Service Center</span>
        </div>
        <div class="rz-ec-hero-text">
          <div class="rz-ec-question">איך נוכל לעזור לכם היום?</div>
          <div class="rz-ec-search"><span>⌕</span><span>חיפוש בקטלוג, פניות וידע…</span></div>
        </div>
        <div class="rz-ec-tiles">
          <div class="rz-ec-tile">
            <div class="rz-ec-tile-icon"><Icon name="laptop" size={20} /></div>
            <div class="rz-ec-tile-title">בקשת חומרה</div>
            <div class="rz-ec-tile-sub">מחשבים ניידים, מסכים, ציוד היקפי</div>
          </div>
          <div class="rz-ec-tile">
            <div class="rz-ec-tile-icon"><Icon name="key" size={20} /></div>
            <div class="rz-ec-tile-title">גישה וחשבונות</div>
            <div class="rz-ec-tile-sub">אפליקציות, VPN, כוננים משותפים</div>
          </div>
          <div class="rz-ec-tile">
            <div class="rz-ec-tile-icon"><Icon name="doc" size={20} /></div>
            <div class="rz-ec-tile-title">פניות HR</div>
            <div class="rz-ec-tile-sub">מכתבים, חופשות, מסמכים</div>
          </div>
          <div class="rz-ec-tile rz-ec-tile--active">
            <div class="rz-ec-tile-icon rz-ec-tile-icon--active"><Icon name="ticket" size={20} /></div>
            <div class="rz-ec-tile-title rz-ec-tile-title--active">הפניות שלי (2)</div>
            <div class="rz-ec-tile-sub">אחת ממתינה למידע שלכם</div>
          </div>
        </div>
        <div class="rz-ec-articles">
          <span class="rz-ec-articles-label">מאמרים פופולריים</span>
          <span class="rz-ec-article-link">איפוס הסיסמה שלכם</span><span class="rz-ec-articles-dot">·</span>
          <span class="rz-ec-article-link">הגדרת VPN מהבית</span><span class="rz-ec-articles-dot">·</span>
          <span class="rz-ec-article-link">בקשת חופשת לידה</span>
        </div>
      </div>
    </section>

    <section class="rz-inside-section">
      <h2 data-reveal class="rz-inside-title">מה יש בפנים</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-module-cta-section">
      <div data-reveal class="rz-module-cta">
        <h2 class="rz-module-cta-title">ראו את מרכז העובד בפעולה</h2>
        <p class="rz-module-cta-sub">פורטל ממותג ביום הראשון — כולל קטלוג לדוגמה.</p>
        <a href="/he/contact" class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  /* ---- hero ---- */
  .rz-module-hero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-module-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-module-hero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1-module {
    font-family: "Heebo", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-module-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
    display: inline-block;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  /* ---- product mock shell ---- */
  .rz-module-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-module-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  /* ---- Employee Center portal mock ---- */
  .rz-ec-hero-text {
    text-align: center;
    padding: 22px 0 26px;
  }
  .rz-ec-question {
    font-family: "Heebo", sans-serif;
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 14px;
  }
  .rz-ec-search {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(56, 224, 200, 0.3);
    border-radius: 12px;
    padding: 13px 18px;
    width: 60%;
    background: var(--inset);
    color: var(--muted2);
    font-size: 14px;
  }
  .rz-ec-tiles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .rz-ec-tile {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 16px;
  }
  .rz-ec-tile--active {
    border: 1px solid rgba(56, 224, 200, 0.3);
    background: rgba(56, 224, 200, 0.06);
  }
  .rz-ec-tile-icon {
    color: #38e0c8;
    margin-bottom: 8px;
  }
  .rz-ec-tile-icon--active {
    color: var(--accent-strong);
  }
  .rz-ec-tile-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 3px;
  }
  .rz-ec-tile-title--active {
    color: var(--accent-strong);
  }
  .rz-ec-tile-sub {
    font-size: 12px;
    color: var(--muted2);
  }
  .rz-ec-articles {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 14px;
    flex-wrap: wrap;
  }
  .rz-ec-articles-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rz-ec-article-link {
    font-size: 13px;
    color: var(--accent-strong);
  }
  .rz-ec-articles-dot {
    color: var(--line2);
  }

  /* ---- what's inside ---- */
  .rz-inside-section {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-title {
    font-family: "Heebo", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-icon {
    color: #38e0c8;
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Heebo", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* ---- CTA ---- */
  .rz-module-cta-section {
    padding: 0 48px 100px;
  }
  .rz-module-cta {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-module-cta-title {
    font-family: "Heebo", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-module-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-ec-tiles {
      grid-template-columns: 1fr 1fr;
    }
    .rz-ec-search {
      width: 100%;
    }
  }
</style>
