---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import { localePath, type Locale } from "../../lib/nav";

const lang: Locale = "he";

const insideCards = [
  {
    icon: "doorIn",
    title: "תהליכי קליטה",
    body: "תהליך אחד מתזמר משימות IT, ITAM, אחזקה ו-HR — עובד חדש פרודוקטיבי ביום הראשון.",
  },
  {
    icon: "doorOut",
    title: "עזיבה והעברות",
    body: "ביטול גישה, החזרת נכסים והעברת ידע במעקב עד להשלמה — שום דבר לא נופל בין הכיסאות.",
  },
  {
    icon: "lock",
    title: "פניות HR חסויות",
    body: "פניות יחסי-עובדים עם אבטחה ברמת השורה: גלויות לשותפי HR המשויכים, סמויות מכל השאר.",
  },
  {
    icon: "doc",
    title: "בקשות מסמכים",
    body: "אישורי העסקה, תעודות וטפסים שמתבקשים מהפורטל וממומשים בתהליך עבודה.",
  },
  {
    icon: "portal",
    title: "פורטל אחד להכול",
    body: "עובדים פונים ל-HR כמו שהם פונים ל-IT — מרכז עובד אחד, חיפוש אחד, רשימת פניות אחת.",
  },
  {
    icon: "sliders",
    title: "שירותי HR בבניית מנהל",
    body: "HR מגדיר בעצמו סוגי פניות, טפסים ותהליכים מהממשק — ללא מפתח בתהליך.",
  },
];
---

<Base
  lang={lang}
  title="RezolveIT — HR Service Management"
  description="תהליכי קליטה ועזיבה, פניות HR חסויות ובקשות מסמכי עובדים — הכול דרך אותו פורטל שהעובדים שלכם כבר משתמשים בו."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/hr" />

    <header class="rz-mhero">
      <div class="rz-mhero-glow"></div>
      <div class="rz-mhero-inner">
        <div class="rz-eyebrow"><Icon name="user" size={16} /> מודול · HR Service Management</div>
        <h1 class="rz-h1">שירותי משאבי אנוש, כמו שירותי IT</h1>
        <p class="rz-hero-sub">
          תהליכי קליטה ועזיבה עם תזמור משימות בין-צוותי, פניות HR חסויות עם בקרת גישה מחמירה, ובקשות מסמכי עובדים —
          הכול דרך אותו פורטל שהעובדים שלכם כבר משתמשים בו.
        </p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </header>

    <section class="rz-mock-section">
      <div data-reveal class="rz-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — HR workspace · Onboarding journey</span>
        </div>
        <div class="rz-hr-grid">
          <div class="rz-hr-panel">
            <div class="rz-hr-panel-head">
              <span class="rz-hr-panel-label">Onboarding · Emma Carter · starts Aug 3</span>
              <span class="rz-hr-panel-done">6 of 9 done</span>
            </div>
            <div class="rz-hr-progress-track"><div class="rz-hr-progress-bar"></div></div>
            <div class="rz-hr-task rz-hr-task--done">
              <span class="rz-hr-task-icon rz-hr-task-icon--done">✓</span>
              <span class="rz-hr-task-text rz-hr-task-text--done">Create accounts &amp; email</span>
              <span class="rz-hr-task-tag">IT</span>
            </div>
            <div class="rz-hr-task rz-hr-task--done">
              <span class="rz-hr-task-icon rz-hr-task-icon--done">✓</span>
              <span class="rz-hr-task-text rz-hr-task-text--done">Assign laptop from stockroom</span>
              <span class="rz-hr-task-tag">ITAM</span>
            </div>
            <div class="rz-hr-task rz-hr-task--active">
              <span class="rz-hr-task-icon rz-hr-task-icon--active">●</span>
              <span class="rz-hr-task-text">Payroll &amp; benefits enrollment</span>
              <span class="rz-hr-task-tag rz-hr-task-tag--active">HR · due Jul 30</span>
            </div>
            <div class="rz-hr-task">
              <span class="rz-hr-task-icon">○</span>
              <span class="rz-hr-task-text">Badge &amp; parking access</span>
              <span class="rz-hr-task-tag">Facilities</span>
            </div>
          </div>
          <div class="rz-hr-panel">
            <div class="rz-hr-panel-label">HR cases</div>
            <div class="rz-hr-case">
              <span class="rz-hr-case-badge rz-hr-case-badge--red"><Icon name="lock" size={13} /></span>
              <div>
                <div class="rz-hr-case-title">HRC-0182 · Confidential — ER case</div>
                <div class="rz-hr-case-sub">Visible: HR partners only (RLS)</div>
              </div>
            </div>
            <div class="rz-hr-case">
              <span class="rz-hr-case-badge rz-hr-case-badge--teal"><Icon name="doc" size={13} /></span>
              <div>
                <div class="rz-hr-case-title">HRC-0187 · Employment letter request</div>
                <div class="rz-hr-case-sub">Auto-generated · awaiting signature</div>
              </div>
            </div>
            <div class="rz-hr-case">
              <span class="rz-hr-case-badge rz-hr-case-badge--amber"><Icon name="leaf" size={13} /></span>
              <div>
                <div class="rz-hr-case-title">HRC-0190 · Parental leave — plan</div>
                <div class="rz-hr-case-sub">Assigned: HR shared services</div>
              </div>
            </div>
            <div class="rz-hr-ai-note"><span>✦</span><span>AI: draft the employment letter for HRC-0187?</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside">
      <h2 data-reveal class="rz-inside-h2">מה יש בפנים</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-card-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-cta-section">
      <div data-reveal class="rz-cta-box">
        <h2 class="rz-cta-h2">ראו את HR Service Management בפעולה</h2>
        <p class="rz-cta-sub">תהליכי קליטה כלולים בנתוני הדוגמה.</p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-hero-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    display: inline-block;
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  .rz-mhero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-mhero-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-mhero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .rz-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-hr-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 16px;
  }
  .rz-hr-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rz-hr-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rz-hr-panel-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rz-hr-panel-done {
    font-size: 12px;
    color: var(--accent-strong);
  }
  .rz-hr-progress-track {
    height: 6px;
    border-radius: 3px;
    background: var(--inset);
  }
  .rz-hr-progress-bar {
    width: 66%;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(90deg, #38e0c8, #2bb8a6);
  }
  .rz-hr-task {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 8px;
    background: var(--inset);
  }
  .rz-hr-task--active {
    background: rgba(56, 224, 200, 0.07);
    border: 1px solid rgba(56, 224, 200, 0.25);
  }
  .rz-hr-task-icon {
    color: var(--muted2);
  }
  .rz-hr-task-icon--done {
    color: var(--accent-strong);
  }
  .rz-hr-task-icon--active {
    color: #ffc46b;
  }
  .rz-hr-task-text {
    font-size: 13.5px;
    color: var(--text2);
  }
  .rz-hr-task-text--done {
    color: var(--muted);
    text-decoration: line-through;
  }
  .rz-hr-task-tag {
    margin-inline-start: auto;
    font-size: 11.5px;
    color: var(--muted2);
  }
  .rz-hr-task-tag--active {
    color: #ffc46b;
  }

  .rz-hr-case {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px;
    border-radius: 8px;
    background: var(--inset);
  }
  .rz-hr-case-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    padding: 3px 6px;
    flex-shrink: 0;
  }
  .rz-hr-case-badge--red {
    color: #ff8484;
    border: 1px solid rgba(255, 132, 132, 0.4);
  }
  .rz-hr-case-badge--teal {
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.4);
  }
  .rz-hr-case-badge--amber {
    color: #ffc46b;
    border: 1px solid rgba(255, 196, 107, 0.4);
  }
  .rz-hr-case-title {
    font-size: 13.5px;
    color: var(--text2);
  }
  .rz-hr-case-sub {
    font-size: 11.5px;
    color: var(--muted2);
  }
  .rz-hr-ai-note {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    background: rgba(56, 224, 200, 0.08);
    border: 1px solid rgba(56, 224, 200, 0.2);
    font-size: 12.5px;
    color: var(--accent-strong2);
  }

  .rz-inside {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-h2 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-card-icon {
    color: var(--rz-accent);
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Heebo", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  .rz-cta-section {
    padding: 0 48px 100px;
  }
  .rz-cta-box {
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-cta-h2 {
    font-family: "Heebo", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-hr-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
