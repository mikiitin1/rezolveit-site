---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import type { Locale } from "../../lib/nav";

const lang: Locale = "he";

const insideCards = [
  {
    icon: "summary",
    title: "סיכום",
    body: "שרשורי פניות ארוכים, רשומות שינוי ועדכוני תיקים מזוקקים למה שחשוב, לפי דרישה.",
  },
  {
    icon: "pencil",
    title: "ניסוח",
    body: "תשובות, הערות פתרון ומאמרי ידע מנוסחים בהקשר — נציגים סוקרים, עורכים ושולחים.",
  },
  {
    icon: "deflect",
    title: "הסטה",
    body: "הפורטל מציע תשובות ידע לפני פתיחת פנייה — פחות פניות, תשובות מהירות יותר.",
  },
  {
    icon: "lock",
    title: "כספת מפתחות מוצפנת",
    body: "מפתחות ספק נשמרים מוצפנים במסד שלכם, נעולי-RLS, מוחלפים ומנוהלים בידי מנהלים מהממשק.",
  },
  {
    icon: "scale",
    title: "מעקות בטיחות מוגדרים",
    body: "טיפול ב-PII, הגבלות היקף ובחירת ספק מוגדרים לכל ארגון — המדיניות שלכם, נאכפת.",
  },
  {
    icon: "swap",
    title: "ללא נעילת ספק",
    body: "החליפו ספקים או מודלים בכל עת — הפלטפורמה אגנוסטית לספק בתכנון.",
  },
];
---

<Base
  lang={lang}
  title="AI Assist — Built-in AI, Your Own Keys | RezolveIT"
  description="סיכום, ניסוח והסטת פניות בכל מודול — מופעל עם מפתחות OpenAI או Anthropic שלכם, מוצפנים במסד הנתונים שלכם. ללא משתני סביבה, ללא נעילת ספק."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/ai-assist" />

    <header class="rz-module-hero">
      <div class="rz-module-glow"></div>
      <div class="rz-module-hero-inner">
        <div class="rz-eyebrow"><Icon name="sparkle" size={16} /> מודול · AI Assist</div>
        <h1 class="rz-h1-module">מבוסס-AI, מופעל עם המפתחות שלכם</h1>
        <p class="rz-module-sub">
          סיכום, ניסוח והסטת פניות בכל מודול — מופעל עם מפתחות OpenAI או Anthropic שלכם, מוצפנים במסד הנתונים שלכם.
          ללא משתני סביבה, ללא נעילת ספק, וללא נתונים שיוצאים דרך צינור AI של מישהו אחר.
        </p>
        <a href="/he/contact" class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </header>

    <section class="rz-module-mock-section">
      <div data-reveal class="rz-module-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Admin Studio · AI providers</span>
        </div>
        <div class="rz-ai-grid">
          <div class="rz-ai-panel">
            <div class="rz-ai-panel-label">כספת מפתחות ספק</div>
            <div class="rz-ai-key-row rz-ai-key-row--active">
              <span class="rz-ai-key-icon"><Icon name="lock" size={16} /></span>
              <div>
                <div class="rz-ai-key-name">Anthropic · claude-sonnet</div>
                <div class="rz-ai-key-detail">sk-ant-••••••••7f2a · מוצפן · נעול-RLS</div>
              </div>
              <span class="rz-ai-key-status rz-ai-key-status--active">פעיל ✓</span>
            </div>
            <div class="rz-ai-key-row">
              <span class="rz-ai-key-icon"><Icon name="lock" size={16} /></span>
              <div>
                <div class="rz-ai-key-name">OpenAI · gpt-4o</div>
                <div class="rz-ai-key-detail">sk-••••••••b91c · מוצפן · נעול-RLS</div>
              </div>
              <span class="rz-ai-key-status rz-ai-key-status--standby">בהמתנה</span>
            </div>
            <div class="rz-ai-add-provider">
              <span>+ הוספת ספק — מנוהל מהממשק, לעולם לא משתנה סביבה</span>
            </div>
            <div class="rz-ai-mini-row">
              <div class="rz-ai-mini">
                <div class="rz-ai-mini-label">מעקות בטיחות</div>
                <div class="rz-ai-mini-value">הסתרת PII פעילה</div>
              </div>
              <div class="rz-ai-mini">
                <div class="rz-ai-mini-label">היקף</div>
                <div class="rz-ai-mini-value rz-ai-mini-value--muted">לכל ארגון</div>
              </div>
            </div>
          </div>
          <div class="rz-ai-panel">
            <div class="rz-ai-panel-label">AI בזרימת העבודה</div>
            <div class="rz-ai-msg">
              <span class="rz-ai-msg-avatar">✦</span>
              <div class="rz-ai-msg-bubble">
                סיכום: המשתמש לא יכול לגשת לכונן משותף לאחר איפוס סיסמה; קרוב לוודאי כרטיס Kerberos ישן. הצעת תיקון
                מנוסחת למטה.
              </div>
            </div>
            <div class="rz-ai-msg">
              <span class="rz-ai-msg-avatar">✦</span>
              <div class="rz-ai-msg-bubble">
                טיוטת תשובה: "הי אמה — נא לנעול ולשחרר את תחנת העבודה, ואז לנסות שוב את הכונן. אם זה נמשך…"
              </div>
            </div>
            <div class="rz-ai-actions">
              <span class="rz-ai-action rz-ai-action--primary">הוספת הטיוטה</span>
              <span class="rz-ai-action rz-ai-action--secondary">יצירה מחדש</span>
              <span class="rz-ai-action rz-ai-action--secondary">הסטה ל-KB-114</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside-section">
      <h2 data-reveal class="rz-inside-title">מה יש בפנים</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-module-cta-section">
      <div data-reveal class="rz-module-cta">
        <h2 class="rz-module-cta-title">ראו את AI Assist בפעולה תוך דקות</h2>
        <p class="rz-module-cta-sub">הביאו את המפתח שלכם. שמרו על הנתונים שלכם.</p>
        <a href="/he/contact" class="rz-btn-cta">הזמנת דמו</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  /* ---- hero ---- */
  .rz-module-hero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-module-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-module-hero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1-module {
    font-family: "Heebo", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-module-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
    display: inline-block;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  /* ---- product mock shell ---- */
  .rz-module-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-module-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  /* ---- AI Assist provider vault mock ---- */
  .rz-ai-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .rz-ai-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rz-ai-panel-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rz-ai-key-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    border-radius: 9px;
    background: var(--inset);
  }
  .rz-ai-key-row--active {
    border: 1px solid rgba(56, 224, 200, 0.25);
  }
  .rz-ai-key-icon {
    color: var(--accent-strong);
    flex-shrink: 0;
  }
  .rz-ai-key-name {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-ai-key-detail {
    font-size: 11.5px;
    color: var(--muted2);
  }
  .rz-ai-key-status {
    margin-inline-start: auto;
    font-size: 11.5px;
    flex-shrink: 0;
  }
  .rz-ai-key-status--active {
    color: var(--accent-strong);
  }
  .rz-ai-key-status--standby {
    color: var(--muted2);
  }
  .rz-ai-add-provider {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    border: 1px dashed var(--border2);
    color: var(--muted2);
    font-size: 13px;
  }
  .rz-ai-mini-row {
    display: flex;
    gap: 9px;
    margin-top: 2px;
  }
  .rz-ai-mini {
    flex: 1;
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 10px;
  }
  .rz-ai-mini-label {
    font-size: 11px;
    color: var(--muted2);
  }
  .rz-ai-mini-value {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--accent-strong);
  }
  .rz-ai-mini-value--muted {
    color: var(--text2);
  }
  .rz-ai-msg {
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .rz-ai-msg-avatar {
    width: 26px;
    height: 26px;
    border-radius: 7px;
    background: linear-gradient(135deg, #38e0c8, #1b9bd8);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
  }
  .rz-ai-msg-bubble {
    background: var(--inset);
    border-radius: 10px;
    padding: 11px 13px;
    font-size: 13px;
    line-height: 1.55;
    color: var(--text2);
  }
  .rz-ai-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .rz-ai-action {
    font-size: 12px;
    border-radius: 6px;
    padding: 5px 10px;
  }
  .rz-ai-action--primary {
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.3);
  }
  .rz-ai-action--secondary {
    color: var(--muted);
    border: 1px solid var(--border2);
  }

  /* ---- what's inside ---- */
  .rz-inside-section {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-title {
    font-family: "Heebo", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-icon {
    color: #38e0c8;
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Heebo", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* ---- CTA ---- */
  .rz-module-cta-section {
    padding: 0 48px 100px;
  }
  .rz-module-cta {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-module-cta-title {
    font-family: "Heebo", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-module-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-ai-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
