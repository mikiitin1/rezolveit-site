---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../lib/nav";

const lang: Locale = "en";
---

<Base
  lang={lang}
  title="RezolveIT — Privacy Policy"
  description="How RezolveIT handles information collected through our website."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/privacy" />

    <header class="rz-legal-hero">
      <div class="rz-legal-hero-glow"></div>
      <div data-reveal class="rz-legal-hero-inner">
        <div class="rz-legal-eyebrow">Privacy</div>
        <h1 class="rz-legal-h1">Privacy Policy</h1>
        <p class="rz-legal-sub">How we handle information collected through our website.</p>
        <span class="rz-legal-updated">Last updated: July 22, 2026</span>
      </div>
    </header>

    <section class="rz-legal-section">
      <div data-reveal class="rz-legal-panel">
        <p>
          RezolveIT respects your privacy. This policy explains, in general terms, what information we collect
          through our website and how we use it.
        </p>
        <h3>What we collect</h3>
        <p>
          Details you submit through our demo and contact forms (such as your name, work email and company), and
          basic usage data collected through cookies and analytics.
        </p>
        <h3>How we use it</h3>
        <p>
          To respond to your requests, provide the demo or information you asked for, keep the site secure, and —
          where permitted — send you relevant product updates. We do not sell your personal data.
        </p>
        <h3>Your choices</h3>
        <p>
          You can decline non-essential cookies and ask us to access, correct or delete your personal data at any
          time by emailing <a href="mailto:privacy@rezolveit.io">privacy@rezolveit.io</a>.
        </p>
        <h3>Updates</h3>
        <p>We may update this policy from time to time; the date above reflects the latest version.</p>
        <p class="rz-legal-disclaimer">
          This document is a general template and is not legal advice. Please have it reviewed by your legal counsel
          before publication.
        </p>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-legal-hero {
    position: relative;
    padding: 80px 48px 30px;
    text-align: center;
    overflow: hidden;
  }
  .rz-legal-hero-glow {
    position: absolute;
    left: 50%;
    top: 34%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 420px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.12), transparent 72%);
    pointer-events: none;
  }
  .rz-legal-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .rz-legal-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-legal-h1 {
    font-family: "Sora", sans-serif;
    font-size: clamp(34px, 4.4vw, 52px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-legal-sub {
    max-width: 600px;
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
  }
  .rz-legal-updated {
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-legal-section {
    padding: 20px 48px 60px;
    max-width: 820px;
    margin: 0 auto;
  }
  .rz-legal-panel {
    border: 1px solid var(--border);
    border-radius: 18px;
    background: var(--panel);
    padding: 40px 44px;
  }
  .rz-legal-panel p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--muted);
    margin: 0 0 14px;
    text-wrap: pretty;
  }
  .rz-legal-panel h3 {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 26px 0 8px;
    color: var(--text);
  }
  .rz-legal-panel p.rz-legal-disclaimer {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--muted2);
    margin: 26px 0 0;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .rz-legal-panel {
      padding: 32px 26px;
    }
  }
</style>
