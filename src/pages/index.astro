    width: 560px;
    height: 560px;
    border: 1px dashed rgba(56, 224, 200, 0.25);
  }
  .rz-hub-ring--inner {
    width: 380px;
    height: 380px;
    border: 1px dashed var(--border);
  }
  .rz-hub-center {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
  }
  .rz-hub-center-mark {
    width: 96px;
    height: 96px;
