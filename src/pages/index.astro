---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { modules, localePath, type Locale } from "../lib/nav";

const lang: Locale = "en";

const marqueeLogos = [
  "Your Logo",
  "Client Two",
  "Client Three",
  "Client Four",
  "Client Five",
  "Client Six",
  "Client Seven",
  "Client Eight",
];

const toolsetCards = [
  {
    title: "Admin Studio",
    body: "Configure forms, fields, choices, lists and workflows from the UI — no developer required.",
  },
  {
    title: "Dashboards & reports",
    body: "Configurable report widgets per module — insight without a separate BI project.",
  },
  {
    title: "Secure by design",
    body: "Row-level security on every record, encrypted keys and a full audit trail, out of the box.",
  },
  {
    title: "Sample data & sandboxes",
    body: "Spin up a working demo environment instantly — live on day one, not month twelve.",
  },
];

const testimonials = [
  {
    quote:
      "We went from signed contract to a live incident queue in four days. Our previous platform took eleven months.",
    name: "Placeholder Name",
    role: "IT Director, mid-size manufacturer",
  },
  {
    quote:
      "Forms, fields and whole workflows change in minutes from the admin UI. Our team stopped filing dev tickets for configuration.",
    name: "Placeholder Name",
    role: "CIO, global enterprise",
  },
  {
    quote:
      "Our PMO finally lives in the same system as our service desk. A demand becomes a project without a single export.",
    name: "Placeholder Name",
    role: "PMO Leader, financial services",
  },
];

const benefits = [
  {
    icon: "bolt",
    title: "Fast deployment",
    body: "Metadata-driven setup plus sample data: a working environment on day one.",
  },
  {
    icon: "sliders",
    title: "Full customization",
    body: "Forms, fields, lists and dashboards — changed by an admin, not a developer.",
  },
  {
    icon: "sparkle",
    title: "AI-native",
    body: "Built-in assistance with your own encrypted keys. Your data stays yours.",
  },
  {
    icon: "lock",
    title: "Secure by design",
    body: "Row-level security on every record, encrypted keys and a full audit trail.",
  },
];
---

<Base
  lang={lang}
  title="RezolveIT — All your service management, made effortless."
  description="RezolveIT gives mid-size organizations enterprise-grade capabilities — incidents, changes, portfolios, self-service, AI assistance — at a fraction of the cost and complexity."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/" />

    <!-- HERO -->
    <header id="top" class="rz-hero">
      <div class="rz-hero-glow"></div>
      <div class="rz-hero-inner">
        <div class="rz-eyebrow">AI-native ESM · Deployable in days</div>
        <h1 class="rz-h1">
          All your service management, <span class="rz-gradient-text">made effortless.</span>
        </h1>
        <p class="rz-hero-sub">
          RezolveIT gives mid-size organizations enterprise-grade capabilities — incidents, changes, portfolios,
          self-service, AI assistance — at a fraction of the cost and complexity.
        </p>
        <a href="#demo" class="rz-btn-cta">Book a Demo</a>
      </div>

      <div data-reveal class="rz-mock rz-mock--hero">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Service Operations</span>
        </div>
        <div class="rz-mock-grid3">
          <div class="rz-mock-nav-col">
            <div class="rz-mock-nav-item rz-mock-nav-item--active">Incidents</div>
            <div class="rz-mock-nav-item">Changes</div>
            <div class="rz-mock-nav-item">Portfolios</div>
            <div class="rz-mock-nav-item">Roadmap</div>
            <div class="rz-mock-nav-item">Employee Center</div>
          </div>
          <div class="rz-mock-panel">
            <div class="rz-mock-label">SLA-aware queue</div>
            <div class="rz-mock-row">
              <span class="rz-badge rz-badge--p1">P1</span>
              <span class="rz-mock-row-text">Email service degraded</span>
              <span class="rz-mock-bar" style="background:linear-gradient(90deg,#FF8484 65%,var(--line2) 65%)"></span>
            </div>
            <div class="rz-mock-row">
              <span class="rz-badge rz-badge--p2">P2</span>
              <span class="rz-mock-row-text">VPN access — Finance</span>
              <span class="rz-mock-bar" style="background:linear-gradient(90deg,#FFC46B 40%,var(--line2) 40%)"></span>
            </div>
            <div class="rz-mock-row">
              <span class="rz-badge rz-badge--p3">P3</span>
              <span class="rz-mock-row-text">Laptop request · new hire</span>
              <span class="rz-mock-bar" style="background:linear-gradient(90deg,#38E0C8 20%,var(--line2) 20%)"></span>
            </div>
          </div>
          <div class="rz-mock-panel">
            <div class="rz-mock-label">Portfolio roadmap</div>
            <div class="rz-mock-roadmap">
              <div class="rz-mock-roadmap-row">
                <span class="rz-mock-roadmap-label">ERP move</span>
                <span class="rz-mock-roadmap-bar" style="background:#38E0C8;width:55%;margin-left:4%"></span>
              </div>
              <div class="rz-mock-roadmap-row">
                <span class="rz-mock-roadmap-label">Portal v2</span>
                <span class="rz-mock-roadmap-bar" style="background:#5BB8F0;width:38%;margin-left:22%"></span>
              </div>
              <div class="rz-mock-roadmap-row">
                <span class="rz-mock-roadmap-label">SSO rollout</span>
                <span class="rz-mock-roadmap-bar" style="background:#8A7BF0;width:30%;margin-left:44%"></span>
              </div>
            </div>
            <div class="rz-mock-ai-note">
              <span>✦</span>
              <span>AI: 3 demands ready to promote to projects</span>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- LOGO MARQUEE -->
    <section class="rz-marquee-section">
      <div class="rz-marquee-caption">Trusted by service teams at</div>
      <div class="rz-marquee-track">
        {[...marqueeLogos, ...marqueeLogos].map((logo) => <span class="rz-marquee-logo">{logo}</span>)}
      </div>
    </section>

    <!-- PLATFORM ROWS -->
    <section class="rz-rows-section">
      <div class="rz-rows-glow"></div>
      <div data-reveal class="rz-rows-heading">
        <div class="rz-rows-mark">R</div>
        <h2 class="rz-h2">One platform for the whole service lifecycle</h2>
      </div>

      <div class="rz-rows">
        <div id="resolve" data-reveal class="rz-row">
          <div class="rz-row-text">
            <div class="rz-row-eyebrow">Resolve · ITSM</div>
            <h3 class="rz-h3">Run IT as a service, start to finish</h3>
            <p class="rz-row-body">
              Incident, Problem and Change management with full lifecycle states, priority matrices and SLA-aware
              queues. A service catalog with fulfillment workflows, a searchable knowledge base, and a CMDB that
              links every record to the services it touches.
            </p>
          </div>
          <div class="rz-mock rz-mock--row">
            <div class="rz-mock-label">Change · CHG-1042</div>
            <div class="rz-mock-steps">
              <span class="rz-step rz-step--done">Draft</span>
              <span class="rz-step rz-step--done">Assess</span>
              <span class="rz-step rz-step--active">Approve</span>
              <span class="rz-step">Implement</span>
              <span class="rz-step">Review</span>
            </div>
            <div class="rz-mock-two-col">
              <div class="rz-mock-mini">
                <div class="rz-mock-mini-label">Impact × Urgency</div>
                <div class="rz-mock-mini-value" style="color:#FFC46B">High · P2</div>
              </div>
              <div class="rz-mock-mini">
                <div class="rz-mock-mini-label">Linked CI</div>
                <div class="rz-mock-mini-value">exchange-prod-01</div>
              </div>
            </div>
          </div>
        </div>

        <div id="plan" data-reveal class="rz-row rz-row--reverse">
          <div class="rz-row-text">
            <div class="rz-row-eyebrow">Plan · EPM</div>
            <h3 class="rz-h3">From idea to roadmap, one hierarchy</h3>
            <p class="rz-row-body">
              Capture ideas, score demands and promote them to projects. Plan on an interactive Gantt with
              milestones and dependencies, prioritize with WSJF and MoSCoW, balance capacity by hours or FTE, and
              tie it all to measurable goals and OKRs.
            </p>
          </div>
          <div class="rz-mock rz-mock--row">
            <div class="rz-mock-label">Roadmap · Q3–Q4</div>
            <div class="rz-mock-gantt">
              <div class="rz-mock-gantt-row">
                <span class="rz-mock-gantt-label">Cloud migration</span>
                <div class="rz-mock-gantt-track">
                  <span class="rz-mock-gantt-bar" style="left:2%;width:48%;background:linear-gradient(90deg,#38E0C8,#2BB8A6)"></span>
                  <span class="rz-mock-gantt-diamond"></span>
                </div>
              </div>
              <div class="rz-mock-gantt-row">
                <span class="rz-mock-gantt-label">Self-service v2</span>
                <div class="rz-mock-gantt-track">
                  <span class="rz-mock-gantt-bar" style="left:28%;width:42%;background:#5BB8F0"></span>
                </div>
              </div>
              <div class="rz-mock-gantt-row">
                <span class="rz-mock-gantt-label">ITAM rollout</span>
                <div class="rz-mock-gantt-track">
                  <span class="rz-mock-gantt-bar" style="left:55%;width:38%;background:#8A7BF0"></span>
                </div>
              </div>
            </div>
            <div class="rz-mock-three-col">
              <div class="rz-mock-mini">
                <div class="rz-mock-mini-label">WSJF score</div>
                <div class="rz-mock-mini-value" style="color:var(--accent-strong)">21.4</div>
              </div>
              <div class="rz-mock-mini">
                <div class="rz-mock-mini-label">Capacity</div>
                <div class="rz-mock-mini-value">82% FTE</div>
              </div>
              <div class="rz-mock-mini">
                <div class="rz-mock-mini-label">OKR</div>
                <div class="rz-mock-mini-value" style="color:#FFC46B">On track</div>
              </div>
            </div>
          </div>
        </div>

        <div id="serve" data-reveal class="rz-row">
          <div class="rz-row-text">
            <div class="rz-row-eyebrow">Serve · Employee Service Center</div>
            <h3 class="rz-h3">A portal your employees actually use</h3>
            <p class="rz-row-body">
              A branded, mobile-friendly self-service portal: browse the catalog, submit requests, track tickets,
              search knowledge. Forms, categories and branding are fully admin-customizable — no code, no
              consultants.
            </p>
          </div>
          <div class="rz-mock rz-mock--row">
            <div class="rz-mock-search"><span>⌕</span><span>How can we help you today?</span></div>
            <div class="rz-mock-tile-grid">
              <div class="rz-mock-tile">
                <div class="rz-mock-tile-icon"><Icon name="laptop" size={20} /></div>
                <div class="rz-mock-tile-label">Request hardware</div>
              </div>
              <div class="rz-mock-tile">
                <div class="rz-mock-tile-icon"><Icon name="key" size={20} /></div>
                <div class="rz-mock-tile-label">Access & accounts</div>
              </div>
              <div class="rz-mock-tile">
                <div class="rz-mock-tile-icon"><Icon name="doc" size={20} /></div>
                <div class="rz-mock-tile-label">Knowledge base</div>
              </div>
              <div class="rz-mock-tile rz-mock-tile--active">
                <div class="rz-mock-tile-icon rz-mock-tile-icon--active"><Icon name="ticket" size={20} /></div>
                <div class="rz-mock-tile-label rz-mock-tile-label--active">My tickets (2)</div>
              </div>
            </div>
          </div>
        </div>

        <div id="assist" data-reveal class="rz-row rz-row--reverse">
          <div class="rz-row-text">
            <div class="rz-row-eyebrow">Assist · Built-in AI</div>
            <h3 class="rz-h3">AI-native, powered by your own keys</h3>
            <p class="rz-row-body">
              Summarization, drafting and deflection across the platform. Bring your own models — OpenAI, Anthropic
              or others — and switch, mix and manage them per organization right from the admin UI, with guardrails
              you control.
            </p>
          </div>
          <div class="rz-mock rz-mock--row">
            <div class="rz-mock-ai-msg">
              <span class="rz-mock-ai-avatar">✦</span>
              <div class="rz-mock-ai-bubble">
                Summary: 4 similar incidents this week point to the same storage CI. Suggest opening a Problem
                record and linking INC-2201…2204.
              </div>
            </div>
            <div class="rz-mock-vault">
              <div>
                <div class="rz-mock-vault-label">Provider key vault</div>
                <div class="rz-mock-vault-value">🔒 Encrypted · RLS-locked · Your DB</div>
              </div>
              <span class="rz-mock-vault-pill">Anthropic ✓</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PLATFORM INFOGRAPHIC -->
    <section id="platform" class="rz-infographic">
      <div class="rz-infographic-glow"></div>
      <div data-reveal class="rz-infographic-heading">
        <h2 class="rz-h2">One platform. One metadata engine.</h2>
        <p class="rz-infographic-sub">
          Every module reads and writes the same data model — click any module to explore it in detail.
        </p>
      </div>

      <div data-reveal class="rz-hub">
        <div class="rz-hub-ring rz-hub-ring--outer"></div>
        <div class="rz-hub-ring rz-hub-ring--inner"></div>
        <div class="rz-hub-center">
          <div class="rz-hub-center-mark">R</div>
          <div class="rz-hub-center-title">Metadata engine</div>
          <div class="rz-hub-center-desc">Tables, forms, workflows &amp; RLS security — all data, not code</div>
        </div>
        {
          modules.map((m) => (
            <a href={localePath(m.path, lang)} class="rz-hub-node" style={`left:${m.hubPos.x};top:${m.hubPos.y}`}>
              <span class="rz-hub-node-icon">
                <Icon name={m.icon} size={22} />
              </span>
              <span class="rz-hub-node-title">{m.title}</span>
              {m.full && <span class="rz-hub-node-full">{m.full}</span>}
              <span class="rz-hub-node-blurb">{m.hubBlurb.en}</span>
            </a>
          ))
        }
      </div>

      <div data-reveal class="rz-toolset">
        <h3 class="rz-h3-center">A platform, not just a toolset</h3>
        <p class="rz-toolset-sub">
          Underneath every module sits one metadata-driven engine. Tables, columns, choice lists, form sections and
          list views are all <span class="rz-strong">data, not code</span> — so admins reshape the platform from the
          UI, and every record is protected by Postgres row-level security. Built on a modern open stack: Next.js
          and Supabase, fully auditable, no proprietary black box.
        </p>
        <div class="rz-toolset-grid">
          {
            toolsetCards.map((c) => (
              <div class="rz-toolset-card">
                <div class="rz-toolset-card-title">{c.title}</div>
                <div class="rz-toolset-card-body">{c.body}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ONE PLATFORM CARDS -->
    <section class="rz-cards-section">
      <h2 data-reveal class="rz-h2-center">Everything connects on one data model</h2>
      <p data-reveal class="rz-cards-sub">
        A demand becomes a project. An incident links to a CI. A portal request follows a catalog workflow. One
        metadata engine underneath it all.
      </p>
      <div class="rz-cards-grid">
        {
          modules.map((m) => (
            <a data-reveal href={localePath(m.path, lang)} class="rz-module-card">
              <div class="rz-module-card-icon">
                <Icon name={m.icon} size={26} />
              </div>
              <h3 class="rz-module-card-title">{m.title}</h3>
              <div class="rz-module-card-full">{m.full}</div>
              <p class="rz-module-card-body">{m.cardBody.en}</p>
              <span class="rz-module-card-cta">Explore →</span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="rz-testimonials-section" data-testimonials>
      <div class="rz-testimonials-glow"></div>
      <div class="rz-testimonials-inner">
        <div class="rz-testimonials-viewport">
          <div class="rz-testimonials-track" data-testimonial-track>
            {
              testimonials.map((tm) => (
                <div class="rz-testimonial-slide">
                  <div class="rz-testimonial-card">
                    <p class="rz-testimonial-quote">&ldquo;{tm.quote}&rdquo;</p>
                    <div class="rz-testimonial-name">{tm.name}</div>
                    <div class="rz-testimonial-role">{tm.role}</div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="rz-testimonial-controls">
          <button class="rz-carousel-btn" data-testimonial-prev aria-label="Previous testimonial">←</button>
          <button class="rz-carousel-btn" data-testimonial-next aria-label="Next testimonial">→</button>
        </div>
      </div>
    </section>

    <!-- KEY BENEFITS -->
    <section class="rz-benefits-section">
      <h2 data-reveal class="rz-h2-center">Why teams pick RezolveIT</h2>
      <div class="rz-benefits-grid">
        {
          benefits.map((b) => (
            <div data-reveal class="rz-benefit">
              <div class="rz-benefit-icon">
                <Icon name={b.icon} size={24} />
              </div>
              <h3 class="rz-benefit-title">{b.title}</h3>
              <p class="rz-benefit-body">{b.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- PRICING -->
    <section id="pricing" class="rz-pricing-section">
      <div data-reveal class="rz-pricing-heading">
        <div class="rz-pricing-eyebrow">Pricing</div>
        <h2 class="rz-h2">Simple pricing, no per-module games</h2>
        <p class="rz-pricing-sub">
          Start on the cloud in minutes, or run it entirely on your own infrastructure. One price, every module
          included.
        </p>
      </div>
      <div class="rz-pricing-grid">
        <div data-reveal class="rz-pricing-card">
          <a href="https://github.com" target="_blank" rel="noopener" title="View on GitHub" class="rz-github-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:block">
              <path
                d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 015 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.04 10.04 0 0022 12.25C22 6.58 17.52 2 12 2z"
              ></path>
            </svg>
          </a>
          <div class="rz-pricing-title">Open Source</div>
          <p class="rz-pricing-desc">Everything you need to get started. Live in minutes with sample data included.</p>
          <div class="rz-pricing-price"><span class="rz-price-num">$0</span><span class="rz-price-unit">Free</span></div>
          <a href={localePath("contact", lang)} class="rz-btn-outline">Get started free</a>
          <div class="rz-pricing-features">
            <div class="rz-feature"><span class="rz-check">✓</span><span>All modules — ITSM, EPM, HR, CMDB, ITAM, Security Ops, AIOps</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>Employee Center &amp; built-in AI Assist</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>Automatic updates &amp; managed backups</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>Email support</span></div>
          </div>
        </div>

        <div data-reveal class="rz-pricing-card rz-pricing-card--featured">
          <div class="rz-pricing-title">Enterprise</div>
          <p class="rz-pricing-desc">Self-hosted or private cloud, with the controls large organizations need.</p>
          <div class="rz-pricing-price"><span class="rz-price-num">Contact us</span></div>
          <div class="rz-pricing-note">Custom plan for your organization</div>
          <a href={localePath("contact", lang)} class="rz-btn-solid">Talk to sales</a>
          <div class="rz-pricing-features">
            <div class="rz-feature"><span class="rz-check">✓</span><span>Everything in OSS</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>AI Enterprise Features — <a href="https://docs.rezolveit.io" target="_blank" rel="noopener" class="rz-underline-link">Docs</a></span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>Self-hosted or single-tenant private cloud</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>SSO / SAML, custom roles &amp; row-level security</span></div>
            <div class="rz-feature"><span class="rz-check">✓</span><span>SLA, priority support &amp; onboarding assistance</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section id="demo" class="rz-final-cta-section">
      <div data-reveal class="rz-final-cta">
        <div class="rz-final-cta-glow"></div>
        <h2 class="rz-h2-cta">See Rezolve<span class="rz-accent-text">IT</span> live in minutes</h2>
        <p class="rz-final-cta-sub">
          A working environment on day one — sample data included. No army of implementation consultants required.
        </p>
        <a href="mailto:demo@rezolveit.io" class="rz-btn-cta">Book a Demo</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-accent-text {
    color: var(--rz-accent);
  }
  .rz-strong {
    color: var(--text2);
  }

  /* ---- typography helpers ---- */
  .rz-h1 {
    font-family: "Sora", sans-serif;
    font-size: clamp(44px, 6vw, 78px);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-gradient-text {
    background: linear-gradient(100deg, #38e0c8, #5bb8f0);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .rz-h2 {
    font-family: "Sora", sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-h2-center {
    font-family: "Sora", sans-serif;
