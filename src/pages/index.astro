  /* ---- hero ---- */
  .rz-hero {
    position: relative;
    padding: 130px 48px 110px;
    text-align: center;
    overflow: hidden;
  }
  .rz-hero-glow {
    position: absolute;
    left: 50%;
    top: 38%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.16), rgba(27, 155, 216, 0.07) 55%, transparent 75%);
    animation: rz-glow 9s ease-in-out infinite;
    pointer-events: none;
  }
  .rz-hero-inner {
    position: relative;
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
  }
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
    letter-spacing: 0.02em;
  }
  .rz-hero-sub {
    max-width: 680px;
    margin: 0;
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 17px;
    padding: 15px 34px;
    border-radius: 12px;
    display: inline-block;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  /* ---- product mocks ---- */
  .rz-mock {
    border: 1px solid var(--border2);
    border-radius: 16px;
    background: var(--panel);
    padding: 22px;
    box-shadow: 0 24px 70px var(--shadow3);
  }
  .rz-mock--hero {
    position: relative;
    max-width: 980px;
    margin: 80px auto 0;
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.07);
    padding: 22px 26px;
    text-align: left;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-left: 14px;
    font-size: 13px;
    color: var(--muted2);
  }
  .rz-mock-grid3 {
    display: grid;
    grid-template-columns: 200px 1fr 1fr;
    gap: 16px;
  }
  .rz-mock-nav-col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .rz-mock-nav-item {
    padding: 9px 12px;
    border-radius: 8px;
    color: #7b7f94;
    font-size: 13.5px;
  }
  .rz-mock-nav-item--active {
    background: rgba(56, 224, 200, 0.12);
    color: var(--accent-strong);
    font-weight: 600;
  }
  .rz-mock-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rz-mock-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rz-mock-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border-radius: 8px;
    background: var(--inset);
  }
  .rz-mock-row-text {
    font-size: 13.5px;
    color: var(--text2);
  }
  .rz-mock-bar {
    margin-left: auto;
    width: 52px;
    height: 5px;
    border-radius: 3px;
  }
  .rz-badge {
    font-size: 11px;
    font-weight: 700;
    border-radius: 5px;
    padding: 2px 7px;
  }
  .rz-badge--p1 {
    color: #ff8484;
    border: 1px solid rgba(255, 132, 132, 0.4);
  }
  .rz-badge--p2 {
    color: #ffc46b;
    border: 1px solid rgba(255, 196, 107, 0.4);
  }
  .rz-badge--p3 {
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.4);
  }
  .rz-mock-roadmap {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .rz-mock-roadmap-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rz-mock-roadmap-label {
    font-size: 12.5px;
    color: var(--muted);
    width: 70px;
    flex-shrink: 0;
  }
  .rz-mock-roadmap-bar {
    height: 9px;
    border-radius: 5px;
    display: block;
  }
  .rz-mock-ai-note {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    background: rgba(56, 224, 200, 0.08);
    border: 1px solid rgba(56, 224, 200, 0.2);
    font-size: 12.5px;
    color: var(--accent-strong2);
  }

  /* ---- marquee ---- */
  .rz-marquee-section {
    border-top: 1px solid var(--border0);
    border-bottom: 1px solid var(--border0);
    padding: 34px 0;
    overflow: hidden;
  }
  .rz-marquee-caption {
    text-align: center;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted2);
    margin-bottom: 26px;
  }
  .rz-marquee-track {
    display: flex;
    width: max-content;
    gap: 72px;
    animation: rz-marquee 28s linear infinite;
    align-items: center;
  }
  .rz-marquee-logo {
    font-family: "Sora", sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--muted3);
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  /* ---- platform rows ---- */
  .rz-rows-section {
    position: relative;
    padding: 90px 48px 40px;
    overflow: hidden;
  }
  .rz-rows-glow {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translate(-50%, -50%);
    width: 1100px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(27, 155, 216, 0.12), transparent 70%);
    pointer-events: none;
  }
  .rz-rows-heading {
    position: relative;
    text-align: center;
    max-width: 760px;
    margin: 0 auto 30px;
  }
  .rz-rows-mark {
    display: inline-flex;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: linear-gradient(135deg, #38e0c8, #1b9bd8);
    align-items: center;
    justify-content: center;
    color: #06121a;
    font-family: "Sora", sans-serif;
    font-weight: 700;
    font-size: 22px;
    margin-bottom: 20px;
  }
  .rz-rows {
    max-width: 1160px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }
  .rz-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 48px;
    padding: 44px 0;
  }
  .rz-row--reverse {
    flex-wrap: wrap-reverse;
    flex-direction: row-reverse;
  }
  .rz-row-text {
    flex: 1 1 380px;
    min-width: 320px;
  }
  .rz-row-eyebrow {
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rz-accent);
    margin-bottom: 12px;
  }
  .rz-row-body {
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--muted);
    margin: 0;
  }
  .rz-mock--row {
    flex: 1 1 420px;
    min-width: 320px;
  }
  .rz-mock-steps {
    display: flex;
    gap: 6px;
    margin-bottom: 18px;
  }
  .rz-step {
    flex: 1;
    text-align: center;
    font-size: 12px;
    padding: 7px 4px;
    border-radius: 7px;
    background: var(--inset);
    color: var(--muted2);
  }
  .rz-step--done {
    background: rgba(56, 224, 200, 0.14);
    color: var(--accent-strong);
  }
  .rz-step--active {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
  }
  .rz-mock-two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .rz-mock-three-col {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }
  .rz-mock-three-col .rz-mock-mini {
    flex: 1;
  }
  .rz-mock-mini {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
  }
  .rz-mock-mini-label {
    font-size: 11.5px;
    color: var(--muted2);
    margin-bottom: 4px;
  }
  .rz-mock-mini-value {
    font-size: 15px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-mock-gantt {
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .rz-mock-gantt-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .rz-mock-gantt-label {
    font-size: 12.5px;
    color: var(--muted);
    width: 96px;
    flex-shrink: 0;
  }
  .rz-mock-gantt-track {
    flex: 1;
    height: 22px;
    border-radius: 6px;
    background: var(--inset);
    position: relative;
  }
  .rz-mock-gantt-bar {
    position: absolute;
    top: 4px;
    bottom: 4px;
    border-radius: 4px;
  }
  .rz-mock-gantt-diamond {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 8px;
    height: 8px;
    background: var(--text);
  }
  .rz-mock-search {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 11px 14px;
    margin-bottom: 16px;
    color: var(--muted2);
    font-size: 14px;
  }
  .rz-mock-tile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .rz-mock-tile {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px;
  }
  .rz-mock-tile--active {
    border: 1px solid rgba(56, 224, 200, 0.3);
    background: rgba(56, 224, 200, 0.06);
  }
  .rz-mock-tile-icon {
    color: #38e0c8;
    margin-bottom: 8px;
  }
  .rz-mock-tile-icon--active {
    color: var(--accent-strong);
  }
  .rz-mock-tile-label {
    font-size: 13.5px;
    font-weight: 600;
  }
  .rz-mock-tile-label--active {
    color: var(--accent-strong);
  }
  .rz-mock-ai-msg {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 14px;
  }
  .rz-mock-ai-avatar {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: linear-gradient(135deg, #38e0c8, #1b9bd8);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }
  .rz-mock-ai-bubble {
    background: var(--inset);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text2);
  }
  .rz-mock-vault {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 10px;
    padding: 12px 14px;
    background: rgba(56, 224, 200, 0.05);
  }
  .rz-mock-vault-label {
    font-size: 12px;
    color: var(--muted2);
    margin-bottom: 2px;
  }
  .rz-mock-vault-value {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--accent-strong);
  }
  .rz-mock-vault-pill {
    font-size: 12px;
    color: var(--muted);
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 4px 9px;
  }

  /* ---- infographic ---- */
  .rz-infographic {
    position: relative;
    padding: 100px 48px 60px;
    overflow: hidden;
  }
  .rz-infographic-glow {
    position: absolute;
    left: 50%;
    top: 55%;
    transform: translate(-50%, -50%);
    width: 1000px;
