  .rz-hub-node-icon {
    font-size: 22px;
    color: var(--rz-accent);
  }
  .rz-hub-node-title {
    font-family: "Sora", sans-serif;
    font-weight: 600;
    font-size: 15.5px;
  }
  .rz-hub-node-full {
    font-size: 10.5px;
    color: var(--muted2);
    margin-top: -2px;
  }
  .rz-hub-node-blurb {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.45;
  }

  .rz-toolset {
