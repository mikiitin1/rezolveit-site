---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import type { Locale } from "../lib/nav";

const lang: Locale = "en";

const insideCards = [
  {
    icon: "target",
    title: "Incident management",
    body: "Full lifecycle states, assignment rules, priority from impact × urgency matrices, and SLA timers on every queue.",
  },
  {
    icon: "search",
    title: "Problem management",
    body: "Group recurring incidents into problems, track root cause and known errors, and publish workarounds to the portal.",
  },
  {
    icon: "swap",
    title: "Change management",
    body: "Draft → assess → approve → implement → review, with risk assessment and CIs linked to every change.",
  },
  {
    icon: "grid",
    title: "Service catalog",
    body: "Catalog items with request fulfillment workflows — approvals, tasks and notifications, all admin-configured.",
  },
  {
    icon: "doc",
    title: "Knowledge base",
    body: "Categorized articles surfaced in the portal search and beside records — deflect tickets before they open.",
  },
  {
    icon: "clock",
    title: "SLA-aware queues",
    body: "Role-based assignment and live SLA countdowns keep breaches visible before they happen, not after.",
  },
];
---

<Base
  lang={lang}
  title="ITSM — IT Service Management | RezolveIT"
  description="Incident, Problem and Change management with full lifecycle states, priority matrices, SLA-aware queues, a service catalog with fulfillment workflows, and knowledge that deflects tickets before they open."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/itsm" />

    <header class="rz-module-hero">
      <div class="rz-module-glow"></div>
      <div class="rz-module-hero-inner">
        <div class="rz-eyebrow"><Icon name="target" size={16} /> Module · ITSM</div>
        <h1 class="rz-h1-module">IT service management, end to end</h1>
        <p class="rz-module-sub">
          Incident, Problem and Change with full lifecycle states, priority matrices, SLA-aware queues, a service
          catalog with fulfillment workflows, and knowledge that deflects tickets before they open.
        </p>
        <a href="/contact" class="rz-btn-cta">Book a Demo</a>
      </div>
    </header>

    <section class="rz-module-mock-section">
      <div data-reveal class="rz-module-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Incident workspace</span>
        </div>
        <div class="rz-itsm-grid">
          <div class="rz-itsm-panel">
            <div class="rz-itsm-panel-head">
              <span class="rz-itsm-label">Open incidents · SLA queue</span>
              <span class="rz-itsm-pill">My group</span>
            </div>
            <div class="rz-itsm-row">
              <span class="rz-badge rz-badge--p1">P1</span>
              <div class="rz-itsm-row-text">
                <div class="rz-itsm-row-title">INC-2201 · Email service degraded</div>
                <div class="rz-itsm-row-sub">exchange-prod-01 · Assigned: A. Turner</div>
              </div>
              <span class="rz-itsm-sla rz-itsm-sla--p1">SLA 0:42</span>
            </div>
            <div class="rz-itsm-row">
              <span class="rz-badge rz-badge--p2">P2</span>
              <div class="rz-itsm-row-text">
                <div class="rz-itsm-row-title">INC-2204 · VPN access — Finance</div>
                <div class="rz-itsm-row-sub">vpn-gw-02 · Assigned: J. Miller</div>
              </div>
              <span class="rz-itsm-sla rz-itsm-sla--p2">SLA 3:10</span>
            </div>
            <div class="rz-itsm-row">
              <span class="rz-badge rz-badge--p3">P3</span>
              <div class="rz-itsm-row-text">
                <div class="rz-itsm-row-title">INC-2209 · Printer offline — Floor 3</div>
                <div class="rz-itsm-row-sub">prn-fl3-01 · Unassigned</div>
              </div>
              <span class="rz-itsm-sla rz-itsm-sla--p3">SLA 7:55</span>
            </div>
            <div class="rz-itsm-ai-note">
              <span>✦</span><span>AI: 4 similar incidents share CI storage-arr-02 — open a Problem?</span>
            </div>
          </div>
          <div class="rz-itsm-panel">
            <div class="rz-itsm-label">INC-2201 · Detail</div>
            <div class="rz-itsm-steps">
              <span class="rz-itsm-step rz-itsm-step--new">New</span>
              <span class="rz-itsm-step rz-itsm-step--active">In progress</span>
              <span class="rz-itsm-step">Resolved</span>
              <span class="rz-itsm-step">Closed</span>
            </div>
            <div class="rz-itsm-mini-grid">
              <div class="rz-itsm-mini">
                <div class="rz-itsm-mini-label">Impact</div>
                <div class="rz-itsm-mini-value rz-itsm-mini-value--danger">High</div>
              </div>
              <div class="rz-itsm-mini">
                <div class="rz-itsm-mini-label">Urgency</div>
                <div class="rz-itsm-mini-value rz-itsm-mini-value--danger">High</div>
              </div>
              <div class="rz-itsm-mini">
                <div class="rz-itsm-mini-label">Linked CI</div>
                <div class="rz-itsm-mini-value">exchange-prod-01</div>
              </div>
              <div class="rz-itsm-mini">
                <div class="rz-itsm-mini-label">Business service</div>
                <div class="rz-itsm-mini-value">Email</div>
              </div>
            </div>
            <div class="rz-itsm-kb">
              <div class="rz-itsm-kb-label">Related knowledge</div>
              <div class="rz-itsm-kb-value">KB-114 · Exchange queue backlog runbook</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside-section">
      <h2 data-reveal class="rz-inside-title">What's inside</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-module-cta-section">
      <div data-reveal class="rz-module-cta">
        <h2 class="rz-module-cta-title">See ITSM live in minutes</h2>
        <p class="rz-module-cta-sub">Sample data included — a working service desk on day one.</p>
        <a href="/contact" class="rz-btn-cta">Book a Demo</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  /* ---- hero ---- */
  .rz-module-hero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-module-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-module-hero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1-module {
    font-family: "Sora", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-module-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
    display: inline-block;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  /* ---- product mock shell ---- */
  .rz-module-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-module-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }
  .rz-badge {
    font-size: 11px;
    font-weight: 700;
    border-radius: 5px;
    padding: 2px 7px;
    flex-shrink: 0;
  }
  .rz-badge--p1 {
    color: #ff8484;
    border: 1px solid rgba(255, 132, 132, 0.4);
  }
  .rz-badge--p2 {
    color: #ffc46b;
    border: 1px solid rgba(255, 196, 107, 0.4);
  }
  .rz-badge--p3 {
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.4);
  }

  /* ---- ITSM incident workspace mock ---- */
  .rz-itsm-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 16px;
  }
  .rz-itsm-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }
  .rz-itsm-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .rz-itsm-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rz-itsm-pill {
    font-size: 12px;
    color: var(--accent-strong);
    border: 1px solid rgba(56, 224, 200, 0.3);
    border-radius: 6px;
    padding: 3px 8px;
  }
  .rz-itsm-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px;
    border-radius: 8px;
    background: var(--inset);
  }
  .rz-itsm-row-text {
    flex: 1;
    min-width: 0;
  }
  .rz-itsm-row-title {
    font-size: 13.5px;
    color: var(--text2);
  }
  .rz-itsm-row-sub {
    font-size: 11.5px;
    color: var(--muted2);
  }
  .rz-itsm-sla {
    margin-inline-start: auto;
    font-size: 11.5px;
    flex-shrink: 0;
  }
  .rz-itsm-sla--p1 {
    color: #ff8484;
  }
  .rz-itsm-sla--p2 {
    color: #ffc46b;
  }
  .rz-itsm-sla--p3 {
    color: var(--accent-strong);
  }
  .rz-itsm-ai-note {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    border-radius: 8px;
    background: rgba(56, 224, 200, 0.08);
    border: 1px solid rgba(56, 224, 200, 0.2);
    font-size: 12.5px;
    color: var(--accent-strong2);
  }
  .rz-itsm-steps {
    display: flex;
    gap: 5px;
  }
  .rz-itsm-step {
    flex: 1;
    text-align: center;
    font-size: 11.5px;
    padding: 6px 2px;
    border-radius: 6px;
    background: var(--inset);
    color: var(--muted2);
  }
  .rz-itsm-step--new {
    background: rgba(56, 224, 200, 0.14);
    color: var(--accent-strong);
  }
  .rz-itsm-step--active {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
  }
  .rz-itsm-mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 9px;
  }
  .rz-itsm-mini {
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 10px;
  }
  .rz-itsm-mini-label {
    font-size: 11px;
    color: var(--muted2);
  }
  .rz-itsm-mini-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-itsm-mini-value--danger {
    color: #ff8484;
  }
  .rz-itsm-kb {
    border: 1px solid var(--border);
    border-radius: 9px;
    padding: 10px;
  }
  .rz-itsm-kb-label {
    font-size: 11px;
    color: var(--muted2);
    margin-bottom: 4px;
  }
  .rz-itsm-kb-value {
    font-size: 13px;
    color: var(--accent-strong);
  }

  /* ---- what's inside ---- */
  .rz-inside-section {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-title {
    font-family: "Sora", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-icon {
    color: #38e0c8;
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* ---- CTA ---- */
  .rz-module-cta-section {
    padding: 0 48px 100px;
  }
  .rz-module-cta {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-module-cta-title {
    font-family: "Sora", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-module-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-itsm-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
