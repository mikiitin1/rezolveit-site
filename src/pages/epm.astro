---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import type { Locale } from "../lib/nav";

const lang: Locale = "en";

const insideCards = [
  {
    icon: "sitemap",
    title: "Portfolio hierarchy",
    body: "Portfolios → programs → projects → tasks, with roll-up status, budgets and health at every level.",
  },
  {
    icon: "funnel",
    title: "Demand & ideas pipeline",
    body: "Idea board → assessment → demand → project. Score, compare and promote with full traceability.",
  },
  {
    icon: "gantt",
    title: "Interactive Gantt roadmap",
    body: "Milestones, dependencies and drag-friendly planning in timeline and kanban views.",
  },
  {
    icon: "scale",
    title: "Prioritization workbench",
    body: "WSJF-style scoring, MoSCoW classification and value/risk grids to decide with evidence, not opinions.",
  },
  {
    icon: "users2",
    title: "Resource & capacity",
    body: "Allocate by hours, FTE or person-days; balance load in the squad and group capacity workbench.",
  },
  {
    icon: "goal",
    title: "Goals & OKRs",
    body: "Measurable targets, goal relationships and check-ins tied directly to the portfolio work that moves them.",
  },
];
---

<Base
  lang={lang}
  title="EPM — Enterprise Portfolio Management | RezolveIT"
  description="Portfolios, programs, projects and tasks in one tree. Capture demands, score them, promote to projects, plan on an interactive Gantt, and tie everything to measurable goals and OKRs."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/epm" />

    <header class="rz-module-hero">
      <div class="rz-module-glow"></div>
      <div class="rz-module-hero-inner">
        <div class="rz-eyebrow"><Icon name="sitemap" size={16} /> Module · Enterprise Portfolio Management</div>
        <h1 class="rz-h1-module">From idea to roadmap, one hierarchy</h1>
        <p class="rz-module-sub">
          Portfolios, programs, projects and tasks in one tree. Capture demands, score them, promote to projects,
          plan on an interactive Gantt, and tie everything to measurable goals and OKRs.
        </p>
        <a href="/contact" class="rz-btn-cta">Book a Demo</a>
      </div>
    </header>

    <section class="rz-module-mock-section">
      <div data-reveal class="rz-module-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Portfolio roadmap · Gantt</span>
        </div>
        <div class="rz-epm-tabs">
          <span class="rz-epm-tab rz-epm-tab--active">Timeline</span>
          <span class="rz-epm-tab">Kanban</span>
          <span class="rz-epm-tab">Capacity</span>
          <span class="rz-epm-tab">Prioritization</span>
        </div>
        <div class="rz-epm-gantt">
          <span></span>
          <div class="rz-epm-gantt-months">
            <span>Jul</span><span>Aug</span><span>Sep</span><span>Oct</span><span>Nov</span><span>Dec</span>
          </div>
          <span class="rz-epm-gantt-label">Cloud migration</span>
          <div class="rz-epm-gantt-track">
            <span
              class="rz-epm-gantt-bar"
              style="left:2%;width:46%;background:linear-gradient(90deg,#38E0C8,#2BB8A6)"
            ></span>
            <span class="rz-epm-gantt-diamond" style="left:49%"></span>
          </div>
          <span class="rz-epm-gantt-label">Self-service v2</span>
          <div class="rz-epm-gantt-track">
            <span class="rz-epm-gantt-bar" style="left:30%;width:40%;background:#5BB8F0"></span>
            <span class="rz-epm-gantt-dep" style="left:22%;width:8%"></span>
          </div>
          <span class="rz-epm-gantt-label">ERP consolidation</span>
          <div class="rz-epm-gantt-track">
            <span class="rz-epm-gantt-bar" style="left:44%;width:50%;background:#8A7BF0"></span>
          </div>
          <span class="rz-epm-gantt-label">SSO rollout</span>
          <div class="rz-epm-gantt-track">
            <span class="rz-epm-gantt-bar" style="left:12%;width:26%;background:#FFC46B"></span>
          </div>
        </div>
        <div class="rz-epm-stats">
          <div class="rz-epm-stat">
            <div class="rz-epm-stat-label">Demands in pipeline</div>
            <div class="rz-epm-stat-value">14 · 3 ready</div>
          </div>
          <div class="rz-epm-stat">
            <div class="rz-epm-stat-label">Top WSJF</div>
            <div class="rz-epm-stat-value rz-epm-stat-value--accent">21.4 · Portal v2</div>
          </div>
          <div class="rz-epm-stat">
            <div class="rz-epm-stat-label">Squad capacity</div>
            <div class="rz-epm-stat-value rz-epm-stat-value--amber">82% FTE</div>
          </div>
          <div class="rz-epm-stat">
            <div class="rz-epm-stat-label">OKR check-in</div>
            <div class="rz-epm-stat-value rz-epm-stat-value--accent">On track</div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside-section">
      <h2 data-reveal class="rz-inside-title">What's inside</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-module-cta-section">
      <div data-reveal class="rz-module-cta">
        <h2 class="rz-module-cta-title">See EPM live in minutes</h2>
        <p class="rz-module-cta-sub">Your PMO and your service desk, finally in one system.</p>
        <a href="/contact" class="rz-btn-cta">Book a Demo</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  /* ---- hero ---- */
  .rz-module-hero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-module-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(91, 184, 240, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-module-hero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1-module {
    font-family: "Sora", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-module-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
    display: inline-block;
    transition:
      transform 0.15s,
      box-shadow 0.15s;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  /* ---- product mock shell ---- */
  .rz-module-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-module-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-inline-start: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  /* ---- EPM Gantt roadmap mock ---- */
  .rz-epm-tabs {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 14px;
  }
  .rz-epm-tab {
    font-size: 13px;
    color: var(--muted2);
    padding: 0 14px 10px;
  }
  .rz-epm-tab--active {
    font-weight: 600;
    color: var(--accent-strong);
    border-bottom: 2px solid #38e0c8;
  }
  .rz-epm-gantt {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 8px;
    align-items: center;
    font-size: 12.5px;
    color: var(--muted);
  }
  .rz-epm-gantt-months {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    color: var(--muted2);
    font-size: 11.5px;
  }
  .rz-epm-gantt-label {
    font-size: 12.5px;
    color: var(--muted);
  }
  .rz-epm-gantt-track {
    height: 24px;
    border-radius: 6px;
    background: var(--inset);
    position: relative;
  }
  .rz-epm-gantt-bar {
    position: absolute;
    top: 4px;
    bottom: 4px;
    border-radius: 5px;
  }
  .rz-epm-gantt-diamond {
    position: absolute;
    top: 8px;
    width: 9px;
    height: 9px;
    background: var(--text);
    transform: rotate(45deg);
  }
  .rz-epm-gantt-dep {
    position: absolute;
    top: 11px;
    height: 2px;
    background: var(--border2);
  }
  .rz-epm-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-top: 18px;
  }
  .rz-epm-stat {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
  }
  .rz-epm-stat-label {
    font-size: 11.5px;
    color: var(--muted2);
    margin-bottom: 3px;
  }
  .rz-epm-stat-value {
    font-size: 17px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-epm-stat-value--accent {
    color: var(--accent-strong);
  }
  .rz-epm-stat-value--amber {
    color: #ffc46b;
  }

  /* ---- what's inside ---- */
  .rz-inside-section {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-title {
    font-family: "Sora", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-icon {
    color: #38e0c8;
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  /* ---- CTA ---- */
  .rz-module-cta-section {
    padding: 0 48px 100px;
  }
  .rz-module-cta {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-module-cta-title {
    font-family: "Sora", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-module-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 720px) {
    .rz-epm-gantt {
      grid-template-columns: 90px 1fr;
    }
    .rz-epm-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
