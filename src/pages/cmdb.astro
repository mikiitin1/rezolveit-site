---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { localePath, type Locale } from "../lib/nav";

const lang: Locale = "en";

const insideCards = [
  {
    icon: "nodes",
    title: "CI classes & attributes",
    body: "Servers, applications, network gear, databases — classes and attributes are metadata, so admins extend them freely.",
  },
  {
    icon: "diamond",
    title: "Business services",
    body: "Map technical CIs to the business services they power, with criticality and ownership on each.",
  },
  {
    icon: "link",
    title: "Relationships & maps",
    body: "Depends-on, runs-on, connects-to — visual dependency maps show blast radius before you touch anything.",
  },
  {
    icon: "target",
    title: "Linked to every record",
    body: "Incidents, problems, changes and assets reference CIs — history and impact live on the CI record.",
  },
  {
    icon: "alert",
    title: "Impact analysis",
    body: "See which services a failing CI affects — and which changes are scheduled against it — instantly.",
  },
  {
    icon: "refresh",
    title: "Import & discovery-ready",
    body: "Populate the CMDB from CSV imports or the API, and keep it fresh with scheduled syncs — no manual data entry.",
  },
];
---

<Base
  lang={lang}
  title="RezolveIT — CMDB"
  description="Configuration items, business services and their relationships in one graph. Every incident, change and asset links to a CI — so impact analysis is a click, not an investigation."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/cmdb" />

    <header class="rz-mhero">
      <div class="rz-mhero-glow"></div>
      <div class="rz-mhero-inner">
        <div class="rz-eyebrow"><Icon name="nodes" size={16} /> Module · CMDB</div>
        <h1 class="rz-h1">Know what runs what</h1>
        <p class="rz-hero-sub">
          Configuration items, business services and their relationships in one graph. Every incident, change and
          asset links to a CI — so impact analysis is a click, not an investigation.
        </p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">Book a Demo</a>
      </div>
    </header>

    <section class="rz-mock-section">
      <div data-reveal class="rz-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — CMDB · Service map: Email</span>
        </div>
        <div class="rz-cmdb-tree">
          <div class="rz-cmdb-node rz-cmdb-node--service">
            <span class="rz-cmdb-node-glyph">◆</span>
            <div>
              <div class="rz-cmdb-node-title">Business service · Email</div>
              <div class="rz-cmdb-node-sub">Criticality: High · Owner: IT Ops</div>
            </div>
          </div>
          <div class="rz-cmdb-connector rz-cmdb-connector--accent"></div>
          <div class="rz-cmdb-branches">
            <div class="rz-cmdb-branch">
              <div class="rz-cmdb-node rz-cmdb-node--alert">
                <span class="rz-cmdb-node-glyph">▣</span>
                <div>
                  <div class="rz-cmdb-node-title rz-cmdb-node-title--alert">exchange-prod-01</div>
                  <div class="rz-cmdb-node-sub rz-cmdb-node-sub--alert">⚠ 1 open P1 · INC-2201</div>
                </div>
              </div>
              <div class="rz-cmdb-connector"></div>
              <div class="rz-cmdb-node">
                <span class="rz-cmdb-node-glyph">▦</span>
                <div>
                  <div class="rz-cmdb-node-title">storage-arr-02</div>
                  <div class="rz-cmdb-node-sub">SAN array · Datacenter A</div>
                </div>
              </div>
            </div>
            <div class="rz-cmdb-branch">
              <div class="rz-cmdb-node">
                <span class="rz-cmdb-node-glyph">▣</span>
                <div>
                  <div class="rz-cmdb-node-title">exchange-prod-02</div>
                  <div class="rz-cmdb-node-sub rz-cmdb-node-sub--ok">Healthy · CHG-1042 scheduled</div>
                </div>
              </div>
              <div class="rz-cmdb-connector"></div>
              <div class="rz-cmdb-node">
                <span class="rz-cmdb-node-glyph">⇅</span>
                <div>
                  <div class="rz-cmdb-node-title">lb-core-01</div>
                  <div class="rz-cmdb-node-sub">Load balancer · depends on</div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="rz-cmdb-stats">
          <div class="rz-cmdb-stat">
            <div class="rz-cmdb-stat-label">CIs tracked</div>
            <div class="rz-cmdb-stat-value">1,284</div>
          </div>
          <div class="rz-cmdb-stat">
            <div class="rz-cmdb-stat-label">Linked records</div>
            <div class="rz-cmdb-stat-value rz-cmdb-stat-value--accent">Incidents · Changes · Assets</div>
          </div>
          <div class="rz-cmdb-stat">
            <div class="rz-cmdb-stat-label">Impact analysis</div>
            <div class="rz-cmdb-stat-value rz-cmdb-stat-value--amber">2 services affected</div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside">
      <h2 data-reveal class="rz-inside-h2">What's inside</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-card-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-cta-section">
      <div data-reveal class="rz-cta-box">
        <h2 class="rz-cta-h2">See the CMDB live in minutes</h2>
        <p class="rz-cta-sub">Sample CIs and service maps included.</p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">Book a Demo</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1 {
    font-family: "Sora", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-hero-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    display: inline-block;
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  .rz-mhero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-mhero-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-mhero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .rz-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-left: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-cmdb-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 0;
  }
  .rz-cmdb-node {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border2);
    border-radius: 11px;
    padding: 10px 18px;
  }
  .rz-cmdb-node--service {
    gap: 10px;
    border: 1px solid rgba(56, 224, 200, 0.4);
    border-radius: 12px;
    padding: 12px 22px;
    background: rgba(56, 224, 200, 0.07);
  }
  .rz-cmdb-node--alert {
    border: 1px solid rgba(255, 132, 132, 0.45);
    background: rgba(255, 132, 132, 0.06);
  }
  .rz-cmdb-node-glyph {
    font-size: 16px;
  }
  .rz-cmdb-node--service .rz-cmdb-node-glyph {
    font-size: 16px;
  }
  .rz-cmdb-node-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-cmdb-node--service .rz-cmdb-node-title {
    font-size: 14px;
    color: var(--accent-strong);
  }
  .rz-cmdb-node-title--alert {
    color: #ffb4b4;
  }
  .rz-cmdb-node-sub {
    font-size: 11px;
    color: var(--muted2);
  }
  .rz-cmdb-node--service .rz-cmdb-node-sub {
    font-size: 11.5px;
  }
  .rz-cmdb-node-sub--alert {
    color: #ff8484;
  }
  .rz-cmdb-node-sub--ok {
    color: var(--accent-strong);
  }
  .rz-cmdb-connector {
    width: 1px;
    height: 22px;
    background: var(--border2);
  }
  .rz-cmdb-connector--accent {
    height: 26px;
    background: linear-gradient(180deg, rgba(56, 224, 200, 0.5), var(--border2));
  }
  .rz-cmdb-branches {
    display: flex;
    gap: 60px;
  }
  .rz-cmdb-branch {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .rz-cmdb-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 14px;
  }
  .rz-cmdb-stat {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
  }
  .rz-cmdb-stat-label {
    font-size: 11.5px;
    color: var(--muted2);
    margin-bottom: 3px;
  }
  .rz-cmdb-stat-value {
    font-size: 17px;
    font-weight: 600;
    color: var(--text2);
  }
  .rz-cmdb-stat-value--accent {
    color: var(--accent-strong);
  }
  .rz-cmdb-stat-value--amber {
    color: #ffc46b;
  }

  .rz-inside {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-h2 {
    font-family: "Sora", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-card-icon {
    color: var(--rz-accent);
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  .rz-cta-section {
    padding: 0 48px 100px;
  }
  .rz-cta-box {
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-cta-h2 {
    font-family: "Sora", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 640px) {
    .rz-cmdb-branches {
      gap: 24px;
    }
    .rz-cmdb-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
