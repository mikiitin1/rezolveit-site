---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import { localePath, type Locale } from "../lib/nav";

const lang: Locale = "en";

const assetRows = [
  { name: "MBP-14 · AST-0412", assignee: "Emma Carter", state: "In use", stateClass: "ok", warranty: "2027-03", warrantyClass: "" },
  { name: "Dell 5540 · AST-0398", assignee: "—", state: "In stock", stateClass: "amber", warranty: "2026-11", warrantyClass: "" },
  { name: "ThinkPad T14 · AST-0231", assignee: "L. Brooks", state: "Retire due", stateClass: "red", warranty: "Expired", warrantyClass: "red" },
  { name: "iPhone 15 · AST-0450", assignee: "A. Turner", state: "In use", stateClass: "ok", warranty: "2027-01", warrantyClass: "" },
];

const insideCards = [
  {
    icon: "refresh",
    title: "Asset lifecycle",
    body: "Order → stock → assign → in use → retire. Every state change logged, every holder known.",
  },
  {
    icon: "laptop",
    title: "Software & licenses",
    body: "Entitlements vs. installs, over-allocation alerts, and true-up numbers ready before the audit.",
  },
  {
    icon: "folder",
    title: "Contracts & renewals",
    body: "Support, lease and subscription contracts with renewal reminders — no more surprise auto-renews.",
  },
  {
    icon: "store",
    title: "Stockrooms",
    body: "Track inventory per location, reserve for onboarding journeys, and restock before you run dry.",
  },
  {
    icon: "link",
    title: "Linked to CMDB & HR",
    body: "An asset is a CI with a holder — onboarding assigns it, offboarding collects it, incidents reference it.",
  },
  {
    icon: "chart",
    title: "Asset dashboards",
    body: "Fleet age, warranty exposure, license spend — configurable report widgets, no BI project needed.",
  },
];
---

<Base
  lang={lang}
  title="RezolveIT — ITAM"
  description="Hardware and software asset lifecycle, license compliance, contracts and stockrooms — tied to the people who hold them, the CIs they run, and the onboarding journeys that assign them."
>
  <div class="rz-page">
    <Nav lang={lang} altHref="/he/itam" />

    <header class="rz-mhero">
      <div class="rz-mhero-glow"></div>
      <div class="rz-mhero-inner">
        <div class="rz-eyebrow"><Icon name="cube" size={16} /> Module · IT Asset Management</div>
        <h1 class="rz-h1">Every asset, from order to retirement</h1>
        <p class="rz-hero-sub">
          Hardware and software asset lifecycle, license compliance, contracts and stockrooms — tied to the people
          who hold them, the CIs they run, and the onboarding journeys that assign them.
        </p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">Book a Demo</a>
      </div>
    </header>

    <section class="rz-mock-section">
      <div data-reveal class="rz-mock">
        <div class="rz-mock-topbar">
          <span class="rz-dot" style="background:#FF5F57"></span>
          <span class="rz-dot" style="background:#FEBC2E"></span>
          <span class="rz-dot" style="background:#28C840"></span>
          <span class="rz-mock-topbar-label">rezolveit.io — Asset workspace</span>
        </div>
        <div class="rz-itam-grid">
          <div class="rz-itam-panel">
            <div class="rz-itam-panel-label">Hardware assets</div>
            <div class="rz-itam-row rz-itam-row--head">
              <span>Asset</span><span>Assigned to</span><span>State</span><span>Warranty</span>
            </div>
            {
              assetRows.map((r) => (
                <div class="rz-itam-row">
                  <span>{r.name}</span>
                  <span class="rz-itam-muted">{r.assignee}</span>
                  <span class={`rz-itam-dot rz-itam-dot--${r.stateClass}`}>● {r.state}</span>
                  <span class={r.warrantyClass === "red" ? "rz-itam-red" : "rz-itam-muted"}>{r.warranty}</span>
                </div>
              ))
            }
          </div>
          <div class="rz-itam-side">
            <div class="rz-itam-panel">
              <div class="rz-itam-panel-label">License compliance</div>
              <div class="rz-itam-license-row">
                <span>Microsoft 365</span><span class="rz-itam-license-value rz-itam-license-value--ok">412 / 450</span>
              </div>
              <div class="rz-itam-license-track"><div class="rz-itam-license-bar" style="width:91%;background:#38E0C8"></div></div>
              <div class="rz-itam-license-row">
                <span>Adobe CC</span><span class="rz-itam-license-value rz-itam-license-value--red">52 / 50 ⚠</span>
              </div>
              <div class="rz-itam-license-track"><div class="rz-itam-license-bar" style="width:100%;background:#FF8484"></div></div>
            </div>
            <div class="rz-itam-panel">
              <div class="rz-itam-panel-label">Contracts</div>
              <div class="rz-itam-contract-title">Dell support renewal</div>
              <div class="rz-itam-contract-sub">Renews in 45 days · ₪84,000/yr</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="rz-inside">
      <h2 data-reveal class="rz-inside-h2">What's inside</h2>
      <div class="rz-inside-grid">
        {
          insideCards.map((c) => (
            <div data-reveal class="rz-inside-card">
              <div class="rz-inside-card-icon">
                <Icon name={c.icon} size={26} />
              </div>
              <h3 class="rz-inside-card-title">{c.title}</h3>
              <p class="rz-inside-card-body">{c.body}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="rz-cta-section">
      <div data-reveal class="rz-cta-box">
        <h2 class="rz-cta-h2">See ITAM live in minutes</h2>
        <p class="rz-cta-sub">Sample fleet and license data included.</p>
        <a href={localePath("contact", lang)} class="rz-btn-cta">Book a Demo</a>
      </div>
    </section>

    <Footer lang={lang} />
  </div>
</Base>

<style>
  .rz-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(56, 224, 200, 0.35);
    border-radius: 100px;
    padding: 7px 16px;
    font-size: 13.5px;
    color: var(--accent-strong2);
  }
  .rz-h1 {
    font-family: "Sora", sans-serif;
    font-size: clamp(38px, 5vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0;
    text-wrap: balance;
  }
  .rz-hero-sub {
    max-width: 640px;
    margin: 0;
    font-size: 18px;
    line-height: 1.6;
    color: var(--muted);
    text-wrap: pretty;
  }
  .rz-btn-cta {
    display: inline-block;
    background: var(--rz-accent);
    color: #06121a;
    font-weight: 600;
    font-size: 16px;
    padding: 14px 30px;
    border-radius: 12px;
  }
  .rz-btn-cta:hover {
    color: #06121a;
    box-shadow: 0 12px 40px rgba(56, 224, 200, 0.4);
  }

  .rz-mhero {
    position: relative;
    padding: 100px 48px 60px;
    text-align: center;
    overflow: hidden;
  }
  .rz-mhero-glow {
    position: absolute;
    left: 50%;
    top: 30%;
    transform: translate(-50%, -50%);
    width: 900px;
    height: 500px;
    background: radial-gradient(closest-side, rgba(56, 224, 200, 0.14), transparent 72%);
    pointer-events: none;
  }
  .rz-mhero-inner {
    position: relative;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }

  .rz-mock-section {
    padding: 20px 48px 80px;
  }
  .rz-mock {
    max-width: 1020px;
    margin: 0 auto;
    border: 1px solid var(--border2);
    border-radius: 18px;
    background: linear-gradient(180deg, var(--panel), var(--panel-deep));
    box-shadow: 0 40px 120px var(--shadow), 0 0 80px rgba(56, 224, 200, 0.06);
    padding: 22px 26px;
  }
  .rz-mock-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }
  .rz-dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .rz-mock-topbar-label {
    margin-left: 14px;
    font-size: 13px;
    color: var(--muted2);
  }

  .rz-itam-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 16px;
  }
  .rz-itam-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
  }
  .rz-itam-panel-label {
    font-size: 12px;
    color: var(--muted2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .rz-itam-row {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 0.8fr;
    gap: 8px;
    align-items: center;
  }
  .rz-itam-row--head {
    font-size: 11.5px;
    color: var(--muted2);
    padding: 0 10px 8px;
    border-bottom: 1px solid var(--border0);
  }
  .rz-itam-row:not(.rz-itam-row--head) {
    font-size: 13px;
    color: var(--text2);
    padding: 10px;
    border-radius: 7px;
  }
  .rz-itam-muted {
    color: var(--muted);
  }
  .rz-itam-red {
    color: #ff8484;
  }
  .rz-itam-dot--ok {
    color: var(--accent-strong);
  }
  .rz-itam-dot--amber {
    color: #ffc46b;
  }
  .rz-itam-dot--red {
    color: #ff8484;
  }

  .rz-itam-side {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rz-itam-license-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
    font-size: 13px;
    color: var(--text2);
  }
  .rz-itam-license-value {
    font-size: 12px;
  }
  .rz-itam-license-value--ok {
    color: var(--accent-strong);
  }
  .rz-itam-license-value--red {
    color: #ff8484;
  }
  .rz-itam-license-track {
    height: 6px;
    border-radius: 3px;
    background: var(--inset);
    margin-bottom: 12px;
  }
  .rz-itam-license-track:last-of-type {
    margin-bottom: 0;
  }
  .rz-itam-license-bar {
    height: 6px;
    border-radius: 3px;
  }
  .rz-itam-contract-title {
    font-size: 13px;
    color: var(--text2);
    margin-bottom: 4px;
  }
  .rz-itam-contract-sub {
    font-size: 12px;
    color: #ffc46b;
  }

  .rz-inside {
    padding: 20px 48px 100px;
    max-width: 1160px;
    margin: 0 auto;
  }
  .rz-inside-h2 {
    font-family: "Sora", sans-serif;
    font-size: clamp(28px, 3.4vw, 40px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 40px;
    text-align: center;
  }
  .rz-inside-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
    gap: 20px;
  }
  .rz-inside-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 26px;
    background: var(--card-bg);
  }
  .rz-inside-card-icon {
    color: var(--rz-accent);
    margin-bottom: 14px;
  }
  .rz-inside-card-title {
    font-family: "Sora", sans-serif;
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
  }
  .rz-inside-card-body {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0;
  }

  .rz-cta-section {
    padding: 0 48px 100px;
  }
  .rz-cta-box {
    max-width: 900px;
    margin: 0 auto;
    border: 1px solid rgba(56, 224, 200, 0.25);
    border-radius: 22px;
    padding: 56px 48px;
    text-align: center;
    background: linear-gradient(180deg, var(--cta1), var(--cta2));
  }
  .rz-cta-h2 {
    font-family: "Sora", sans-serif;
    font-size: clamp(26px, 3.4vw, 38px);
    letter-spacing: -0.02em;
    font-weight: 700;
    margin: 0 0 12px;
  }
  .rz-cta-sub {
    font-size: 16px;
    color: var(--muted);
    margin: 0 0 28px;
  }

  @media (max-width: 780px) {
    .rz-itam-grid {
      grid-template-columns: 1fr;
    }
    .rz-itam-row {
      grid-template-columns: 1.4fr 1fr 1fr 0.8fr;
      font-size: 11px;
    }
  }
</style>
